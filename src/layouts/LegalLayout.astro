---
import '../styles/global.css';
import Footer from '../components/Footer.astro';
import { content, type Locale } from '../i18n/content';

interface Props {
  title: string;
  locale?: Locale;
}

const { title, locale = 'de' } = Astro.props;
const c = content[locale];
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} – Marjorie</title>
    <meta name="robots" content="noindex" />
  </head>
  <body>
    <header class="legal-header">
      <a href="/" class="nav-logo">Marjorie</a>
      <a href="/" class="legal-back">← Startseite</a>
    </header>
    <main class="legal">
      <h1>{title}</h1>
      <slot />
    </main>
    <Footer content={c} locale={locale} />
  </body>
</html>
